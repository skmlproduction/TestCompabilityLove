<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- API 29+: edge-to-edge без принудительного scrim (см. enableEdgeToEdge) -->
    <style name="Theme.LoveTester" parent="Theme.LoveTester.Base">
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:enforceNavigationBarContrast">false</item>
        <item name="android:enforceStatusBarContrast">false</item>
    </style>

    <style name="Theme.LoveTester.Splash" parent="Theme.SplashScreen">
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:enforceNavigationBarContrast">false</item>
        <item name="android:enforceStatusBarContrast">false</item>
    </style>
</resources>
