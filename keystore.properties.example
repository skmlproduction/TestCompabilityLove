# Скопируйте в keystore.properties (файл в .gitignore, не коммитить):
#   cp keystore.properties.example keystore.properties
#
# Production upload key (Play Console):
#   LOVETEST_KEYSTORE_PASS='***' LOVETEST_KEY_PASS='***' ./scripts/generate_upload_keystore.sh
#
# Локальный smoke-test:
#   ./scripts/generate_debug_upload_keystore.sh

storeFile=build/keystore/lovetest-upload.jks
storePassword=CHANGE_ME
keyAlias=upload
keyPassword=CHANGE_ME
